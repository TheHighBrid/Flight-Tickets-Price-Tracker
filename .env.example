# Flask
SECRET_KEY=change-this-to-a-random-secret-key
DATABASE_URL=sqlite:///instance/flight_tracker.db

# Amadeus API (get free sandbox keys at https://developers.amadeus.com)
# If not set, the app runs in demo mode with mock flight data
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOSTNAME=test

# Email alerts (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=flighttracker@example.com

# Price check interval in hours (default: 6)
PRICE_CHECK_INTERVAL_HOURS=6

# Set to 'false' to disable background scheduler
SCHEDULER_ENABLED=true
